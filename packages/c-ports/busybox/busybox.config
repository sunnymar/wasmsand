# BusyBox 1.37.0 .config — codepod default POSIX userland.
#
# Built via `make KCONFIG_ALLCONFIG=busybox.config allnoconfig`, so this
# file is an OVERRIDE list, not a full .config.  Anything not mentioned
# here stays disabled.  See docs/superpowers/plans/2026-04-25-busybox-as-default-coreutils.md
# for the migration's purpose and the applet partition (96 enabled here,
# 13 still ship as Rust standalones).

# ─── Runtime baseline ─────────────────────────────────────────────────
CONFIG_BUSYBOX=y
CONFIG_DESKTOP=n
CONFIG_EXTRA_COMPAT=n
CONFIG_LONG_OPTS=y
CONFIG_SHOW_USAGE=y
CONFIG_FEATURE_VERBOSE_USAGE=n
CONFIG_FEATURE_COMPRESS_USAGE=n
CONFIG_LFS=y
CONFIG_INSTALL_APPLET_DONT=y
CONFIG_NO_DEBUG_LIB=y
CONFIG_FEATURE_BUFFERS_USE_MALLOC=y
CONFIG_PAM=n
CONFIG_FEATURE_SUID=n
# Shell built into busybox is disabled — codepod has its own shell-exec.
CONFIG_SH_IS_NONE=y
CONFIG_BASH_IS_NONE=y
CONFIG_ASH=n
CONFIG_HUSH=n
CONFIG_FEATURE_EDITING=n
CONFIG_FEATURE_TAB_COMPLETION=n
# multicall dispatch via argv[0] still works without PREFER_APPLETS;
# leaving it off avoids pulling vfork_daemon_rexec.o, which references
# wasm32-unsupported __wasm_setjmp/__wasm_longjmp (no proper sjlj
# runtime in our wasi-libc build).
CONFIG_FEATURE_PREFER_APPLETS=n

# ─── Applets (96) — derived from /tmp/migrate.txt ∩ upstream applet table ─
CONFIG_BB_ARCH=y
CONFIG_AWK=y
CONFIG_FEATURE_AWK_LIBM=y
CONFIG_BASE32=y
CONFIG_BASE64=y
CONFIG_BASENAME=y
CONFIG_BC=y
CONFIG_CAL=y
CONFIG_CAT=y
CONFIG_CHGRP=y
CONFIG_CHOWN=y
CONFIG_FEATURE_CHOWN_LONG_OPTIONS=y
CONFIG_CKSUM=y
CONFIG_CMP=y
CONFIG_COMM=y
CONFIG_CP=y
CONFIG_FEATURE_CP_LONG_OPTIONS=y
CONFIG_CUT=y
CONFIG_FEATURE_CUT_REGEX=y
CONFIG_DC=y
CONFIG_DD=y
CONFIG_FEATURE_DD_IBS_OBS=y
CONFIG_FEATURE_DD_STATUS=y
CONFIG_DF=y
CONFIG_FEATURE_DF_FANCY=y
CONFIG_DIFF=y
CONFIG_FEATURE_DIFF_LONG_OPTIONS=y
CONFIG_FEATURE_DIFF_DIR=y
CONFIG_DIRNAME=y
CONFIG_DU=y
CONFIG_ECHO=y
CONFIG_FEATURE_FANCY_ECHO=y
CONFIG_ENV=y
CONFIG_EXPAND=y
CONFIG_EXPR=y
CONFIG_FACTOR=y
CONFIG_FALSE=y
CONFIG_FIND=y
CONFIG_FEATURE_FIND_PRINT0=y
CONFIG_FEATURE_FIND_MTIME=y
CONFIG_FEATURE_FIND_MMIN=y
CONFIG_FEATURE_FIND_PERM=y
CONFIG_FEATURE_FIND_TYPE=y
CONFIG_FEATURE_FIND_XDEV=y
CONFIG_FEATURE_FIND_MAXDEPTH=y
CONFIG_FEATURE_FIND_NEWER=y
CONFIG_FEATURE_FIND_INUM=y
CONFIG_FEATURE_FIND_EXEC=y
CONFIG_FEATURE_FIND_EXEC_PLUS=y
CONFIG_FEATURE_FIND_USER=y
CONFIG_FEATURE_FIND_GROUP=y
CONFIG_FEATURE_FIND_NOT=y
CONFIG_FEATURE_FIND_DEPTH=y
CONFIG_FEATURE_FIND_PAREN=y
CONFIG_FEATURE_FIND_SIZE=y
CONFIG_FEATURE_FIND_PRUNE=y
CONFIG_FEATURE_FIND_DELETE=y
CONFIG_FEATURE_FIND_PATH=y
CONFIG_FEATURE_FIND_REGEX=y
CONFIG_FEATURE_FIND_LINKS=y
CONFIG_FEATURE_FIND_EMPTY=y
CONFIG_FEATURE_FIND_CONTEXT=n
CONFIG_FOLD=y
CONFIG_GREP=y
CONFIG_FEATURE_GREP_CONTEXT=y
CONFIG_EGREP=y
CONFIG_FGREP=y
CONFIG_GZIP=y
CONFIG_GUNZIP=y
CONFIG_FEATURE_GZIP_LONG_OPTIONS=y
CONFIG_HEAD=y
CONFIG_FEATURE_FANCY_HEAD=y
CONFIG_HEXDUMP=y
CONFIG_HOSTID=y
CONFIG_HOSTNAME=y
CONFIG_ID=y
CONFIG_LINK=y
CONFIG_LN=y
CONFIG_LOGNAME=y
CONFIG_LS=y
CONFIG_FEATURE_LS_FILETYPES=y
CONFIG_FEATURE_LS_FOLLOWLINKS=y
CONFIG_FEATURE_LS_RECURSIVE=y
CONFIG_FEATURE_LS_WIDTH=y
CONFIG_FEATURE_LS_SORTFILES=y
CONFIG_FEATURE_LS_TIMESTAMPS=y
CONFIG_FEATURE_LS_USERNAME=y
CONFIG_FEATURE_LS_COLOR=y
CONFIG_FEATURE_LS_COLOR_IS_DEFAULT=n
CONFIG_MD5SUM=y
CONFIG_MKDIR=y
CONFIG_MKTEMP=y
CONFIG_MV=y
CONFIG_NICE=y
CONFIG_NL=y
CONFIG_NOHUP=y
CONFIG_NPROC=y
CONFIG_OD=y
CONFIG_PASTE=y
CONFIG_PATCH=y
CONFIG_PRINTENV=y
CONFIG_PRINTF=y
CONFIG_READLINK=y
CONFIG_FEATURE_READLINK_FOLLOW=y
CONFIG_REALPATH=y
CONFIG_REV=y
CONFIG_RM=y
CONFIG_RMDIR=y
CONFIG_SED=y
CONFIG_SEQ=y
CONFIG_SHA1SUM=y
CONFIG_SHA256SUM=y
CONFIG_SHA512SUM=y
CONFIG_SHUF=y
CONFIG_SLEEP=y
CONFIG_FEATURE_FANCY_SLEEP=y
CONFIG_SORT=y
CONFIG_FEATURE_SORT_BIG=y
CONFIG_SPLIT=y
CONFIG_FEATURE_SPLIT_FANCY=y
CONFIG_STAT=y
CONFIG_FEATURE_STAT_FORMAT=y
CONFIG_STRINGS=y
CONFIG_SUM=y
CONFIG_TAC=y
CONFIG_TAIL=y
CONFIG_FEATURE_FANCY_TAIL=y
CONFIG_TAR=y
CONFIG_FEATURE_TAR_LONG_OPTIONS=y
CONFIG_FEATURE_TAR_AUTODETECT=y
CONFIG_FEATURE_TAR_FROM=y
CONFIG_FEATURE_TAR_OLDGNU_COMPATIBILITY=y
CONFIG_FEATURE_TAR_OLDSUN_COMPATIBILITY=y
# tar --to-command: builds via our execl shim, but ENOSYSes at runtime
# (see compat/include/unistd.h for the rationale — wasm has no process
# replacement primitive).  Useful if a future runtime adds one.
CONFIG_FEATURE_TAR_TO_COMMAND=y
CONFIG_TEE=y
CONFIG_TIMEOUT=y
CONFIG_TOUCH=y
CONFIG_FEATURE_TOUCH_SUSV3=y
CONFIG_TR=y
CONFIG_FEATURE_TR_CLASSES=y
CONFIG_FEATURE_TR_EQUIV=y
CONFIG_TREE=y
CONFIG_TRUE=y
CONFIG_TRUNCATE=y
CONFIG_TSORT=y
CONFIG_UNAME=y
CONFIG_UNEXPAND=y
CONFIG_UNIQ=y
CONFIG_UNLINK=y
CONFIG_UNZIP=y
CONFIG_UPTIME=y
CONFIG_USERS=y
CONFIG_WC=y
CONFIG_FEATURE_WC_LARGE=y
CONFIG_WHO=y
CONFIG_WHOAMI=y
CONFIG_XARGS=y
CONFIG_FEATURE_XARGS_SUPPORT_CONFIRMATION=y
CONFIG_FEATURE_XARGS_SUPPORT_QUOTES=y
CONFIG_FEATURE_XARGS_SUPPORT_TERMOPT=y
CONFIG_FEATURE_XARGS_SUPPORT_ZERO_TERM=y
CONFIG_XXD=y
CONFIG_YES=y
CONFIG_ZCAT=y

# ─── Process tools (BusyBox) ──────────────────────────────────────────
# We expose /proc/{uptime,version,cpuinfo,meminfo,diskstats} via
# vfs/proc-provider.ts.  Per-PID entries (/proc/<pid>/stat) aren't there
# yet, so ps/top/pgrep/pkill will report empty / no-match — benign, not
# crashy.  Adding per-PID proc is a tracked follow-up; until then these
# applets work as much as the data layer allows.
CONFIG_KILL=y
CONFIG_KILLALL=y
CONFIG_KILLALL5=y
CONFIG_PIDOF=y
CONFIG_PGREP=y
CONFIG_PKILL=y
CONFIG_PS=y
# top: interactive curses UI — would loop in the sandbox waiting on a TTY.
CONFIG_TOP=n
CONFIG_PSTREE=y
CONFIG_FUSER=y

# ─── Init / login / privilege transitions ─────────────────────────────
# Sandbox is single-user with no init, so the daemons / privilege
# applets stay off.  `su` / `sudo` specifically: codepod ships its own
# Rust no-op shims that already do the right thing; BusyBox's su would
# attempt real privilege transitions and just fail.  Leave =n so our
# shims are the canonical entries on PATH.
CONFIG_INIT=n
CONFIG_HALT=n
CONFIG_REBOOT=n
CONFIG_POWEROFF=n
CONFIG_LOGIN=n
CONFIG_NOLOGIN=n
CONFIG_GETTY=n
CONFIG_SU=n
CONFIG_SULOGIN=n
CONFIG_PASSWD=n
CONFIG_ADDUSER=n
CONFIG_DELUSER=n
CONFIG_ADDGROUP=n
CONFIG_DELGROUP=n
CONFIG_CHPASSWD=n
CONFIG_CRYPTPW=n
CONFIG_MKPASSWD=n
CONFIG_VLOCK=n
CONFIG_LAST=n

# ─── Filesystem / kernel ops ──────────────────────────────────────────
# No real block devices and no kernel modules in the sandbox.  mount /
# umount specifically: not impossible (could surface "mount a host dir"
# as a future capability) but not worth shipping in this round; the
# sandbox already exposes mounts via the Sandbox API at create time.
CONFIG_MOUNT=n
CONFIG_UMOUNT=n
CONFIG_SWAPON=n
CONFIG_SWAPOFF=n
CONFIG_INSMOD=n
CONFIG_RMMOD=n
CONFIG_LSMOD=n
CONFIG_MODPROBE=n
CONFIG_MODINFO=n
CONFIG_DEPMOD=n
CONFIG_FDISK=n
CONFIG_MKFS_EXT2=n
CONFIG_MKFS_MINIX=n
CONFIG_MKFS_REISER=n
CONFIG_MKFS_VFAT=n
CONFIG_FSCK=n
CONFIG_LOSETUP=n
CONFIG_BLOCKDEV=n
CONFIG_BLKDISCARD=n
CONFIG_BLKID=n

# ─── Network daemons ──────────────────────────────────────────────────
# Codepod has its own host network bridge for outbound traffic; we don't
# host inbound listeners by default.  These could be enabled later for
# specific use cases (httpd serving sandbox files, etc.) but are off
# now to keep the default attack surface small.
CONFIG_HTTPD=n
CONFIG_FTPD=n
CONFIG_TELNETD=n
CONFIG_INETD=n
CONFIG_TFTPD=n
CONFIG_DHCPRELAY=n
CONFIG_UDHCPC=n
CONFIG_UDHCPD=n

# ─── Logging ──────────────────────────────────────────────────────────
# syslogd/klogd/logger/logread can be supported in the sandbox if/when
# we want them — BusyBox syslogd writes to a regular file so the VFS
# carries it.  Off for now; tracked as a real option (not a hard "no").
CONFIG_SYSLOGD=n
CONFIG_KLOGD=n
CONFIG_LOGGER=n
CONFIG_LOGREAD=n

# ─── Mail ─────────────────────────────────────────────────────────────
# No MTA in the sandbox.
CONFIG_SENDMAIL=n
CONFIG_POPMAILDIR=n
CONFIG_MAKEMIME=n
CONFIG_REFORMIME=n
