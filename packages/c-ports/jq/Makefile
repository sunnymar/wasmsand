# jq port built via cpcc. Upstream jqlang/jq lives at upstream/ as a
# git submodule pinned to a release tag (jq-1.8.1).  Build is
# out-of-tree — we never mutate the submodule directly; configure +
# generated files live under build/.  Patches (if any) live in
# patches/*.patch and are applied to a worktree copy at configure time.

REPO_ROOT := $(shell cd ../../.. && pwd)
FIXTURES := $(REPO_ROOT)/packages/orchestrator/src/platform/__tests__/fixtures
JQ_VERSION := 1.8.1
UPSTREAM := upstream
PATCHES_DIR := patches
BUILD_DIR := build
WORK_DIR := $(BUILD_DIR)/work
GUEST_COMPAT_INCLUDE := $(abspath ../../guest-compat/include)
GUEST_COMPAT_LIB := $(REPO_ROOT)/packages/guest-compat/build/libcodepod_guest_compat.a

CPCC := $(REPO_ROOT)/target/release/cpcc
CPAR := $(REPO_ROOT)/target/release/cpar
CPRANLIB := $(REPO_ROOT)/target/release/cpranlib

# WASI emulated subsystems jq needs:
# - signal: fenv-related; harmless to enable
# - mman:   jv_dtoa-side mmap probes (unused at runtime but configure may probe)
# - process-clocks: gettimeofday() in builtin.c
WASI_EMULATED_CFLAGS := -D_WASI_EMULATED_SIGNAL -D_WASI_EMULATED_MMAN -D_WASI_EMULATED_PROCESS_CLOCKS
WASI_EMULATED_LDFLAGS := -lwasi-emulated-signal -lwasi-emulated-mman -lwasi-emulated-process-clocks -Wl,-u,__main_argc_argv

.PHONY: all submodule-init worktree configure build copy-fixtures clean ensure-toolchain ensure-compat

all: $(BUILD_DIR)/jq.wasm

# Initialize the submodule if the user cloned without --recurse-submodules.
submodule-init:
	@if [ ! -f $(UPSTREAM)/configure ]; then \
		echo "==> Initializing jq submodule"; \
		cd $(REPO_ROOT) && git submodule update --init packages/c-ports/jq/$(UPSTREAM); \
	fi

ensure-toolchain:
	cd $(REPO_ROOT) && cargo build --release -p cpcc-toolchain

ensure-compat:
	$(MAKE) -C $(REPO_ROOT)/packages/guest-compat lib

# Materialize a clean worktree copy from the submodule.  We rsync
# rather than build in-tree so the submodule stays pristine and
# `git submodule status` doesn't go dirty after every build.  The
# submodule ships configure.ac but no generated configure (release
# tarballs have it pre-built; git checkouts don't), so we autoreconf
# here.  Requires host autoconf/automake/libtool — same dependency
# wasi-sdk users have for any autotools port.
$(WORK_DIR)/configure: submodule-init
	mkdir -p $(WORK_DIR)
	rsync -a --delete --exclude='.git' $(UPSTREAM)/ $(WORK_DIR)/
	# Apply any patches we carry on top of upstream.  Empty dir is fine.
	if [ -d $(PATCHES_DIR) ] && ls $(PATCHES_DIR)/*.patch >/dev/null 2>&1; then \
		for p in $(PATCHES_DIR)/*.patch; do \
			echo "==> Applying $$p"; \
			git -C $(WORK_DIR) apply --whitespace=nowarn $(abspath $$p); \
		done; \
	fi
	cd $(WORK_DIR) && autoreconf -i

# jq's configure expects autoconf-generated Makefiles; we run it
# with cpcc as CC so all probes go through the WASI toolchain.
# --without-oniguruma drops the regex backend (separate port if
# wanted later); --disable-decnum drops the vendored decNumber lib;
# --disable-docs skips manpage generation.
configure: $(WORK_DIR)/Makefile

$(WORK_DIR)/Makefile: $(WORK_DIR)/configure ensure-toolchain
	cd $(WORK_DIR) && \
		CC="$(CPCC)" AR="$(CPAR)" RANLIB="$(CPRANLIB)" \
		CFLAGS="$(WASI_EMULATED_CFLAGS)" \
		LDFLAGS="$(WASI_EMULATED_LDFLAGS)" \
		./configure \
			--host=wasm32-wasi \
			--without-oniguruma \
			--disable-shared \
			--enable-static \
			--disable-maintainer-mode \
			--disable-docs \
			--disable-decnum

# Build the jq binary.  The release tarball ships parser.c / lexer.c
# pre-generated; the submodule does NOT — configure regenerates them
# from .y/.l using bison/flex.  builtin.inc / config_opts.inc /
# version.h are generated by `make` before linking.
#
# VERSION is empty in the submodule build because AC_INIT(jq, [])
# defers to scripts/version which needs a real .git/ — our rsync
# strips that.  Override on the make command line so the JQ_VERSION
# header substitution produces "jq-$(JQ_VERSION)" instead of "jq-".
$(BUILD_DIR)/jq.wasm: configure ensure-compat
	# BUILT_SOURCES (builtin.inc, config_opts.inc, version.h) is only
	# wired into the `all` target.  Building `jq` directly skips it,
	# so we make the generated headers explicitly first.
	cd $(WORK_DIR) && \
		$(MAKE) VERSION="$(JQ_VERSION)" \
			src/builtin.inc src/config_opts.inc src/version.h
	cd $(WORK_DIR) && \
		CPCC_ARCHIVE="$(GUEST_COMPAT_LIB)" \
		CPCC_INCLUDE="$(GUEST_COMPAT_INCLUDE)" \
		$(MAKE) CC="$(CPCC)" AR="$(CPAR)" RANLIB="$(CPRANLIB)" \
			VERSION="$(JQ_VERSION)" jq
	cp $(WORK_DIR)/jq $(BUILD_DIR)/jq.wasm

copy-fixtures: $(BUILD_DIR)/jq.wasm
	cp $(BUILD_DIR)/jq.wasm $(FIXTURES)/jq.wasm

clean:
	rm -rf $(BUILD_DIR)
