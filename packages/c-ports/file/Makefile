# file/libmagic port built via cpcc.  Upstream file/file lives at
# upstream/ as a git submodule pinned to a release tag (FILE5_47).
# Out-of-tree pattern (mirrors jq port): rsync upstream → build/work/,
# apply patches/*.patch (none today), bootstrap autotools, cross-
# compile with cpcc.
#
# Magic database (magic.mgc) is generated by a HOST build of the same
# upstream tree, since cross-compile would need a wasm-runnable `file
# -C` pass which we don't have.  We invoke the host compiler under
# build/host/ to produce magic.mgc, then ship it alongside the wasm
# binary.

REPO_ROOT := $(shell cd ../../.. && pwd)
FIXTURES := $(REPO_ROOT)/packages/orchestrator/src/platform/__tests__/fixtures
FILE_VERSION := 5.47
UPSTREAM := upstream
PATCHES_DIR := patches
BUILD_DIR := build
WORK_DIR := $(BUILD_DIR)/work
HOST_DIR := $(BUILD_DIR)/host
GUEST_COMPAT_INCLUDE := $(abspath ../../guest-compat/include)
GUEST_COMPAT_LIB := $(REPO_ROOT)/packages/guest-compat/build/libcodepod_guest_compat.a

CPCC := $(REPO_ROOT)/target/release/cpcc
CPAR := $(REPO_ROOT)/target/release/cpar
CPRANLIB := $(REPO_ROOT)/target/release/cpranlib

# WASI emulated subsystems file/libmagic touches:
# - mman: der.c does a file-backed mmap of the input we're typing.
#   Emulated mmap on wasi only supports private anonymous; we fall
#   back to malloc+read via a compat shim.
# - signal: compress.c references SIGPIPE/sigaction (gated behind
#   compression flags we'll have disabled, but harmless to enable).
# - process-clocks: gettimeofday probes during configure.
WASI_EMULATED_CFLAGS := -D_WASI_EMULATED_SIGNAL -D_WASI_EMULATED_MMAN -D_WASI_EMULATED_PROCESS_CLOCKS
WASI_EMULATED_LDFLAGS := -lwasi-emulated-signal -lwasi-emulated-mman -lwasi-emulated-process-clocks -Wl,-u,__main_argc_argv

.PHONY: all submodule-init host-build configure build copy-fixtures clean ensure-toolchain ensure-compat

all: $(BUILD_DIR)/file.wasm $(BUILD_DIR)/magic.mgc

# Initialize the submodule if missing.
submodule-init:
	@if [ ! -f $(UPSTREAM)/configure.ac ]; then \
		echo "==> Initializing file submodule"; \
		cd $(REPO_ROOT) && git submodule update --init packages/c-ports/file/$(UPSTREAM); \
	fi

ensure-toolchain:
	cd $(REPO_ROOT) && cargo build --release -p cpcc-toolchain

ensure-compat:
	$(MAKE) -C $(REPO_ROOT)/packages/guest-compat lib

# ── Worktree setup ──
$(WORK_DIR)/configure.ac: submodule-init
	mkdir -p $(WORK_DIR)
	rsync -a --delete --exclude='.git' $(UPSTREAM)/ $(WORK_DIR)/
	if [ -d $(PATCHES_DIR) ] && ls $(PATCHES_DIR)/*.patch >/dev/null 2>&1; then \
		for p in $(PATCHES_DIR)/*.patch; do \
			echo "==> Applying $$p"; \
			git -C $(WORK_DIR) apply --whitespace=nowarn $(abspath $$p); \
		done; \
	fi

$(WORK_DIR)/configure: $(WORK_DIR)/configure.ac
	cd $(WORK_DIR) && autoreconf -fi

# ── Host build → magic.mgc ──
# We need the magic database compiled by a host-runnable `file -C`.
# Build upstream once with the system compiler in build/host/, copy
# out magic.mgc, throw the rest away.  This is independent of the
# wasm build and only needs to re-run when upstream changes.
$(BUILD_DIR)/magic.mgc: $(WORK_DIR)/configure
	rm -rf $(HOST_DIR)
	mkdir -p $(HOST_DIR)
	rsync -a --delete --exclude='.git' $(UPSTREAM)/ $(HOST_DIR)/
	cd $(HOST_DIR) && \
		autoreconf -fi && \
		./configure \
			--disable-shared --enable-static \
			--disable-libseccomp \
			--disable-bzlib --disable-zlib --disable-xzlib \
			--disable-zstdlib --disable-lzlib && \
		$(MAKE)
	cp $(HOST_DIR)/magic/magic.mgc $(BUILD_DIR)/magic.mgc

# ── Wasm cross-compile ──
$(WORK_DIR)/Makefile: $(WORK_DIR)/configure ensure-toolchain
	cd $(WORK_DIR) && \
		CC="$(CPCC)" AR="$(CPAR)" RANLIB="$(CPRANLIB)" \
		CFLAGS="$(WASI_EMULATED_CFLAGS)" \
		LDFLAGS="$(WASI_EMULATED_LDFLAGS)" \
		./configure \
			--host=wasm32-wasi \
			--prefix=/usr \
			--disable-shared --enable-static \
			--disable-libseccomp \
			--disable-bzlib --disable-zlib --disable-xzlib \
			--disable-zstdlib --disable-lzlib

configure: $(WORK_DIR)/Makefile

$(BUILD_DIR)/file.wasm: $(WORK_DIR)/Makefile ensure-compat
	# Skip building magic/ subdir (cross-compile would invoke our wasm
	# `file -C`, which wasn't built yet).  We assemble magic.mgc via
	# the host build above instead.
	#
	# `make file` skips BUILT_SOURCES (only `make all` wires those in),
	# but file's src/ subdir generates magic.h from magic.h.in via a
	# sed substitution.  Build it first.
	cd $(WORK_DIR)/src && $(MAKE) magic.h
	cd $(WORK_DIR)/src && \
		CPCC_ARCHIVE="$(GUEST_COMPAT_LIB)" \
		CPCC_INCLUDE="$(GUEST_COMPAT_INCLUDE)" \
		$(MAKE) CC="$(CPCC)" AR="$(CPAR)" RANLIB="$(CPRANLIB)" file
	cp $(WORK_DIR)/src/file $(BUILD_DIR)/file.wasm

copy-fixtures: $(BUILD_DIR)/file.wasm $(BUILD_DIR)/magic.mgc
	cp $(BUILD_DIR)/file.wasm $(FIXTURES)/file.wasm
	cp $(BUILD_DIR)/magic.mgc $(FIXTURES)/magic.mgc

clean:
	rm -rf $(BUILD_DIR)
